{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/refs/heads/main/tauri/tauri.conf.schema.json",
  "productName": "AI Econometrics Copilot",
  "version": "0.1.0",
  "identifier": "com.ai-econometrics-copilot.app",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../../frontend && npm run dev",
    "beforeBuildCommand": "cd ../../frontend && npm run build:static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Econometrics Copilot",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": {
      "../../sample_data/*": "sample_data/"
    },
    "externalBin": [
      "binaries/ai-econometrics-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": {
        "sidecar": true
      }
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$LOCALAPPDATA/**", "$HOME/**"]
      }
    }
  }
}
