# ============================================================
# AI Econometrics Copilot — Environment Configuration
# Copy to .env and adjust as needed.
# All ECOPILOT_ vars are read by pydantic-settings (case-insensitive).
# ============================================================

# --- Backend: Core ---
ECOPILOT_DATABASE_URL=sqlite:///./data/ai_econometrics.db
ECOPILOT_DATA_DIR=data
ECOPILOT_UPLOAD_DIR=data/uploads
ECOPILOT_ARTIFACT_DIR=data/artifacts
ECOPILOT_MAX_UPLOAD_SIZE_BYTES=52428800          # 50 MB
ECOPILOT_ALLOWED_EXTENSIONS=.csv,.xlsx,.xls
ECOPILOT_LOG_LEVEL=INFO

# --- Backend: CORS ---
ECOPILOT_CORS_ORIGINS=["http://localhost:3000"]

# --- Backend: Analysis Thresholds ---
ECOPILOT_PREVIEW_ROW_COUNT=10
ECOPILOT_OUTLIER_IQR_MULTIPLIER=1.5
ECOPILOT_OUTLIER_ZSCORE_THRESHOLD=3.0
ECOPILOT_HIGH_SKEW_THRESHOLD=1.0
ECOPILOT_VIF_WARNING_THRESHOLD=5.0
ECOPILOT_VIF_SEVERE_THRESHOLD=10.0
ECOPILOT_HETEROSKEDASTICITY_ALPHA=0.05

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
